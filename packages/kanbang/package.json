{
  "name": "kanbang",
  "version": "0.1.5",
  "description": "Lightweight kanban drag & drop with injectable CSS config",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/theojcw-source/kanbang.git",
    "directory": "packages/kanbang"
  },
  "keywords": [
    "kanban",
    "drag-and-drop",
    "dnd",
    "sortable"
  ]
}
